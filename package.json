{
  "name": "anim-engine",
  "version": "0.6.0",
  "private": false,
  "description": "JavaScript library for animating numbers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LukeCarlThompson/anim-engine.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.txt",
    "SKILL.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "npm run lint && npm run test:watch && vite",
    "build": "npm run lint && npm run test && tsc && vite build",
    "preview": "vite preview",
    "check:types": "tsc --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "npm run lint && npm run test && storybook build",
    "prepublishOnly": "npm run build",
    "bench": "vitest bench src/benchmarks/ --run",
    "bench:baseline": "vitest bench src/benchmarks/ --run --outputJson baselines/benchmark.json",
    "bench:compare": "vitest bench src/benchmarks/ --run --compare baselines/benchmark.json",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "fmt": "oxfmt src/"
  },
  "devDependencies": {
    "@storybook/addon-docs": "10.5.0",
    "@storybook/html": "10.5.0",
    "@storybook/html-vite": "10.5.0",
    "@typescript/typescript6": "^6.0.2",
    "gsap": "3.15.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "storybook": "10.5.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vite-plugin-dts": "5.0.3",
    "vitest": "4.1.10"
  }
}
